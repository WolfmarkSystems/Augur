{
  "$schema": "https://schema.tauri.app/config/capability",
  "identifier": "default",
  "description": "Default capability for the AUGUR desktop window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:path:default",
    "core:window:default",
    "core:app:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:default"
  ]
}
